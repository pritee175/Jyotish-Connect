# Firebase Configuration — get these from Firebase Console > Project Settings > Your Apps
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Firebase Cloud Messaging VAPID Key (for push notifications)
# Get from: Firebase Console > Project Settings > Cloud Messaging > Web Push certificates
VITE_FIREBASE_VAPID_KEY=your_vapid_key_here

# Your father's Firebase UID — set this after he registers once
# Go to Firebase Console > Authentication > Users, copy his UID
VITE_ADMIN_UID=paste_fathers_uid_here

# Your father's UPI ID (shown to customers on the payment screen)
VITE_ADMIN_UPI=yourname@upi

# Razorpay Payment Gateway (get from https://razorpay.com)
# Test mode keys start with rzp_test_, live mode with rzp_live_
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id

# Backend only (DO NOT add VITE_ prefix - keep these secret)
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
